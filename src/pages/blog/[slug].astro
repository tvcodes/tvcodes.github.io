---
import {
  getCollection,
  render,
} from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/common/Navbar.astro";
import Footer from "../../components/common/Footer.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => {
    const sameCategoryPosts = posts
      .filter((p) => p.data.category === post.data.category)
      .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

    const currentIndex = sameCategoryPosts.findIndex((p) => p.id === post.id);
    const prevPost = sameCategoryPosts[currentIndex + 1] ?? null;

    return {
      params: { slug: post.id },
      props: { post, prevPost },
    };
  });
}

const { post, prevPost } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.pubDate.toLocaleDateString("vi-VN", {
  year: "numeric",
  month: "long",
  day: "numeric",
  hour: "2-digit",
  minute: "2-digit",
});

const categoryTitle: Record<string, string> = {
  live: "To Live",
  die: "To Die",
  remember: "To Remember",
};
---

<BaseLayout title={post.data.title}>
  <Navbar />

  <div class="post-detail section">
    <aside class="post-sidebar">
      <div class="post-author">
        {post.data.author.avatar && (
          <img
            src={post.data.author.avatar}
            alt={post.data.author.name}
            class="post-author-avatar"
          />
        )}
        <div>
          <p class="post-author-name">{post.data.author.name}</p>
          <p class="post-author-role">{post.data.author.role}</p>
        </div>
      </div>

      <p class="post-date">{formattedDate}</p>

      {post.data.tags.length > 0 && (
        <div class="post-tags-block">
          <h4>Categories</h4>
          <div class="post-tags">
            {post.data.tags.map((tag) => (
              <span class="post-tag">{tag}</span>
            ))}
          </div>
        </div>
      )}

      {post.data.featuredIn.length > 0 && (
        <div class="post-featured-block">
          <h4>Also Featured In</h4>
          {post.data.featuredIn.map((item) => (
            <p class="post-featured-item">{item}</p>
          ))}
        </div>
      )}
    </aside>

    <article class="post-content">
      <h1>{post.data.title}</h1>

      {post.data.heroImage && (
        <figure class="post-hero-figure">
          <img
            src={post.data.heroImage}
            alt={post.data.title}
            class="post-hero-image"
          />
          {(post.data.heroImageCaption || post.data.heroImageCredit) && (
            <figcaption>
              {post.data.heroImageCaption && <p>{post.data.heroImageCaption}</p>}
              {post.data.heroImageCredit && (
                <p class="post-hero-credit">Credit: {post.data.heroImageCredit}</p>
              )}
            </figcaption>
          )}
        </figure>
      )}

      <div class="post-body">
        <Content />
      </div>

      {prevPost && (
        <section class="post-more">
          <h2>More from {categoryTitle[post.data.category]}</h2>

          <a href={`/blog/${prevPost.id}`} class="post-more-nav">
            ← Previous Post
          </a>

          <a href={`/blog/${prevPost.id}`} class="post-more-card">
            {prevPost.data.heroImage && (
              <img
                src={prevPost.data.heroImage}
                alt={prevPost.data.title}
                class="post-more-image"
              />
            )}
            <h3>{prevPost.data.title}</h3>
            <p class="post-more-date">
              {prevPost.data.pubDate.toLocaleDateString("vi-VN", {
                year: "numeric",
                month: "long",
                day: "numeric",
              }).toUpperCase()}
            </p>
          </a>
        </section>
      )}
    </article>
  </div>

  <Footer />
</BaseLayout>